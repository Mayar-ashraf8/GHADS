<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.RadioMenuItem?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane id="AnchorPane" prefHeight="330.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.ChangePasswordController">

    <children>
       <MenuBar fx:id="menubar" layoutY="1.0" prefHeight="25" prefWidth="900">
    <menus>
        <Menu text="File">
            <items>
                <MenuItem onAction="#handleExit" text="Exit" />
            </items>
        </Menu>
        <Menu text="Format">
            <items>
                <Menu text="Font Family">
                    <items>
                        <RadioMenuItem fx:id="arialbtn" onAction="#arialFontHandle" text="Arial" />
                        <RadioMenuItem fx:id="SansSerifbtn" onAction="#SansSerifFontHandle" text="Sans Serif" />
                        <RadioMenuItem fx:id="timesnewbtn" onAction="#TimeNewFontHandle" text="Times New Roman" />
                    </items>
                </Menu>
                <Menu text="Font Size">
                    <items>
                        <RadioMenuItem fx:id="smallbtn" onAction="#smallFontHandle" text="Small" />
                        <RadioMenuItem fx:id="mediambtn" onAction="#MediamFontHandle" text="Medium" />
                        <RadioMenuItem fx:id="largebtn" onAction="#LargeFontHandle" text="Large" />
                    </items>
                </Menu>
                <Menu text="Background Color">
                    <items>
                        <RadioMenuItem fx:id="lightbtn" onAction="#LightBackgroud" text="Light" />
                        <RadioMenuItem fx:id="darkbtn" onAction="#darkBackgroud" text="Dark" />
                    </items>
                </Menu>
            </items>
        </Menu>
        <Menu text="Help">
            <items>
                <MenuItem onAction="#aboutHandle" text="About" />
            </items>
        </Menu>
    </menus>
</MenuBar>
        <PasswordField fx:id="currentPassField" layoutX="348.0" layoutY="101.0" prefHeight="26.0" prefWidth="191.0" promptText="Current Password" />
        <PasswordField fx:id="newPassField" layoutX="348.0" layoutY="145.0" prefHeight="26.0" prefWidth="191.0" promptText="New Password" />
        <Button layoutX="395.0" layoutY="187.0" onAction="#savePassHandle" prefHeight="26.0" prefWidth="85.0" text="Save" />
        <Button layoutX="395.0" layoutY="230.0" onAction="#resetBtnHandle" prefHeight="26.0" prefWidth="86.0" text="Reset" />
    </children>
</AnchorPane>
