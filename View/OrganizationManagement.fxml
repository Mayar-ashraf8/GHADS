<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.RadioMenuItem?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/26" fx:controller="Controllers.OrganizationManagementController">

    <top>
        <MenuBar fx:id="menuBar">
            <menus>
                <!-- File Menu -->
                <Menu text="File">
                    <MenuItem onAction="#handleExit" text="Exit" />
                </Menu>

                <!-- Format Menu -->
                <Menu text="Format">
                    <!-- Font Family -->
                    <Menu text="Font Family">
                        <RadioMenuItem fx:id="arialbtn" onAction="#arialFontHandle" text="Arial" />
                        <RadioMenuItem fx:id="SansSerifbtn" onAction="#SansSerifFontHandle" text="Sans Serif" />
                        <RadioMenuItem fx:id="timesnewbtn" onAction="#TimeNewFontHandle" text="Times New Roman" />
                    </Menu>

                    <!-- Font Size -->
                    <Menu text="Font Size">
                        <RadioMenuItem fx:id="smallbtn" onAction="#smallFontHandle" text="Small" />
                        <RadioMenuItem fx:id="mediambtn" onAction="#MediamFontHandle" text="Medium" />
                        <RadioMenuItem fx:id="largebtn" onAction="#LargeFontHandle" text="Large" />
                    </Menu>

                    <Menu text="Background Color">
                        <RadioMenuItem fx:id="lightbtn" onAction="#LightBackgroud" text="Light" />
                        <RadioMenuItem fx:id="darkbtn" onAction="#darkBackgroud" text="Dark" />
                    </Menu>
                </Menu>

                <Menu text="Help">
                    <MenuItem onAction="#aboutHandle" text="About App" />
                </Menu>
            </menus>
        </MenuBar>
    </top>

    <center>
        <VBox alignment="CENTER" spacing="10" style="-fx-padding: 20;">
            <TextField fx:id="orgNameField" promptText="Organization Name" />
            <TextField fx:id="orgTypeField" promptText="Organization Type" />
            <TextField fx:id="orgContactField" promptText="Contact Info" />

            <HBox alignment="CENTER" spacing="10">
                <Button onAction="#addOrgHandle" text="Add Organization" />
                <Button onAction="#editOrgHandle" text="Edit Organization" />
                <Button onAction="#deleteOrgHandle" text="Delete Organization" />
                <Button onAction="#resetBtnHandle" text="Reset" />
                <Button onAction="#backBtnHandle" text="Back" />
            </HBox>

            <TableView fx:id="orgTable" prefHeight="300" prefWidth="600">
                <columns>
                    <TableColumn fx:id="nameCol" prefWidth="200" text="Name" />
                    <TableColumn fx:id="typeCol" prefWidth="200" text="Type" />
                    <TableColumn fx:id="contactCol" prefWidth="200" text="Contact Info" />
                </columns>
            </TableView>
        </VBox>
    </center>
</BorderPane>
