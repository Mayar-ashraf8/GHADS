<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.RadioMenuItem?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="420" prefWidth="500" styleClass="login-pane" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.LoginController">
    <children>
        <!-- شريط القوائم -->

        <!-- العنوان -->
        <Label layoutX="167.0" layoutY="100.0" prefHeight="50.0" prefWidth="178.0" style="-fx-alignment: center;" styleClass="title-label" text="GHADS Login" />

        <!-- اللوجو -->

        <!-- اسم المستخدم -->
        <Label layoutX="100" layoutY="210" styleClass="field-label" text="Username:" />
        <TextField fx:id="usernameFeild" layoutX="200" layoutY="205" prefWidth="200" promptText="Enter your Name" styleClass="input-field" />

        <!-- كلمة المرور -->
        <Label layoutX="100" layoutY="250" styleClass="field-label" text="Password:" />
        <PasswordField fx:id="passFeild" layoutX="200" layoutY="245" prefWidth="200" promptText="Enter Your Password" styleClass="input-field" />

        <!-- الأزرار -->
        <Button layoutX="200" layoutY="290" onAction="#handleLogin_btn" prefWidth="90" styleClass="login-button" text="Login" />
        <Button layoutX="310" layoutY="290" onAction="#handleResetbtn" prefWidth="90" styleClass="reset-button" text="Reset" />

        <!-- رسالة الخطأ -->
        <Label fx:id="messageLabel" layoutX="200" layoutY="330" styleClass="error-label" />
      <MenuBar fx:id="menuBar" prefHeight="26.0" prefWidth="500.0">
        <menus>
          <Menu mnemonicParsing="false" text="File">
            <items>
              <MenuItem mnemonicParsing="false" onAction="#handleExit" text="Exit" />
            </items>
          </Menu>
          <Menu mnemonicParsing="false" text="Format">
               <items>
                  <Menu mnemonicParsing="false" text="Font Family">
                    <items>
                        <RadioMenuItem fx:id="arialbtn" mnemonicParsing="false" onAction="#arialFontHandle" text="Arial" />
                        <RadioMenuItem fx:id="SansSerifbtn" mnemonicParsing="false" onAction="#SansSerifFontHandle" text="Sans Serif" />
                        <RadioMenuItem fx:id="timesnewbtn" mnemonicParsing="false" onAction="#TimeNewFontHandle" text="Times New" />
                    </items>
                  </Menu>
                  <Menu mnemonicParsing="false" text="Font Size">
                     <items>
                        <RadioMenuItem fx:id="smallbtn" mnemonicParsing="false" onAction="#smallFontHandle" text="Small" />
                        <RadioMenuItem fx:id="mediambtn" mnemonicParsing="false" onAction="#MediamFontHandle" text="Mediam" />
                        <RadioMenuItem fx:id="largebtn" mnemonicParsing="false" onAction="#LargeFontHandle" text="Large" />
                     </items>
                  </Menu>
                  <Menu mnemonicParsing="false" text="Background Color">
                     <items>
                        <RadioMenuItem fx:id="lightbtn" mnemonicParsing="false" onAction="#LightBackgroud" text="Light" />
                        <RadioMenuItem fx:id="darkbtn" mnemonicParsing="false" onAction="#darkBackgroud" text="Dark" />
                     </items>
                  </Menu>
               </items>
          </Menu>
          <Menu mnemonicParsing="false" text="Help">
            <items>
              <MenuItem mnemonicParsing="false" onAction="#aboutHandle" text="About" />
            </items>
          </Menu>
        </menus>
      </MenuBar>
    </children>
</AnchorPane>
